# Scraper backend (Trulia/Hotpads, Skip Trace).
# Local:   http://localhost:8080
# Deployed: set your Railway URL
# VITE_SCRAPER_BACKEND_URL=http://localhost:8080

# Optional tables (if your Supabase schema omits some scraper tables)
# VITE_SKIP_OPTIONAL_TABLES=true

# Optional: show Admin on production for these emails (comma-separated).
# VITE_ADMIN_EMAILS=info@brivano.io,admin@brivano.io

# Supabase — required at BUILD time (Vite). VITE_SUPABASE_PROJECT_ID is NOT read by the app.
# Use Project URL + anon public key from the SAME project (Settings → API). No trailing space on URL.
# Mismatched URL + key → 401 / auth errors.
# VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_public_key_here
# Optional alias: VITE_SUPABASE_ANON_KEY=(same as publishable key)
#
# Lovable: add VITE_SUPABASE_URL + VITE_SUPABASE_PUBLISHABLE_KEY in env/secrets, then Publish.
# Never commit real keys — copy this file to .env locally only.
