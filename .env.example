# Production defaults for brivano.io are in `src/integrations/supabase/constants.ts` (anon key is public).
# You can still override with VITE_SUPABASE_URL + VITE_SUPABASE_PUBLISHABLE_KEY for staging or key rotation.
#
# IMPORTANT — if you remove defaults, the live site needs build-time env:
# Cloud Secrets are often injected for Supabase Edge Functions only, NOT for `vite build`.
# If brivano.io (or GitHub → Vercel/Netlify/Cloudflare) builds without env, the JS bundle has no Supabase URL/key.
# Fix: add these as build-time env on the system that runs `npm run build`:
#   VITE_SUPABASE_URL
#   VITE_SUPABASE_PUBLISHABLE_KEY   (same value as Supabase "anon public" key)
# GitHub: repo Settings → Secrets and variables → Actions → add the two names above.
# Docs: https://docs.lovable.dev/tips-tricks/external-deployment-hosting
#
# If the browser console shows 404 on Supabase REST URLs, those tables are not in your project yet.
# Either run your SQL migrations in Supabase, or set VITE_SKIP_OPTIONAL_TABLES=true to skip optional features.
#
# Local dev: copy this file to `.env` (never commit `.env`). Lovable editor `.env.example` alone does nothing.
# Optional aliases vite.config also reads: sb_url + sb_anon, SUPABASE_URL + SUPABASE_ANON_KEY, VITE_SB_URL + VITE_SB_ANON.
# No quotes. Remove VITE_SUPABASE_PROJECT_ID everywhere — unused. Never put SUPABASE_SERVICE_KEY in the frontend.

# Supabase — required at BUILD time for Lovable/production (same project for URL + anon key):
# VITE_SUPABASE_URL=https://xgcvdduwrvgquurhngzq.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_public_key

# Scout People Search + footer enrich — Edge only (no Railway for these flows):
# VITE_PEOPLE_SEARCH_URL=https://xgcvdduwrvgquurhngzq.supabase.co/functions/v1/people-search
# VITE_WATERFALL_ENRICH_URL=https://xgcvdduwrvgquurhngzq.supabase.co/functions/v1/data-waterfall-enrich
# Set APOLLO_API_KEY (+ strict vendor keys) on Supabase Edge secrets. Unset SCRAPER_BACKEND_URL on Edge.

# Scraper backend — Web Scraper / skip-trace / Scrapy / company-search still use Railway (or local :8080).
# Local Flask: http://localhost:8080
# Railway: https://resplendent-empathy-production.up.railway.app
# VITE_SCRAPER_BACKEND_URL=https://your-app.up.railway.app
# Lovable Cloud → Secrets (VITE_* is blocked there): use SCRAPER_BACKEND_URL with the same Railway URL.
# SCRAPER_BACKEND_URL=https://resplendent-empathy-production.up.railway.app
# Do NOT point scraper URL at data-waterfall-enrich — Scout enrich uses VITE_WATERFALL_ENRICH_URL instead.
# If unset on Lovable/brivano.io hosts, code falls back to resplendent-empathy-production.up.railway.app automatically.

# Google Jobs (Brivano Scout → Job Scraper): default calls Edge Function `google-jobs-search` via Supabase.
# Set secret SERPAPI_API_KEY on the same Supabase project (Dashboard → Edge Functions → Secrets), then deploy:
#   supabase functions deploy google-jobs-search --project-ref YOUR_REF
# To keep using Flask POST /api/google-jobs/search instead (local SERPAPI_API_KEY in Python .env):
# VITE_GOOGLE_JOBS_BACKEND=scraper

# Optional tables (if your Supabase schema omits some scraper tables)
# VITE_SKIP_OPTIONAL_TABLES=true

# Local dev only: skip "not enough credits" checks and do not write to `credit_usage`.
# Remove or set false for production / real billing behavior.
# VITE_BYPASS_CREDITS=true

# Optional: show Admin on production for these emails (comma-separated).
# VITE_ADMIN_EMAILS=info@brivano.io,admin@brivano.io

# Supabase — required at BUILD time. URL + anon key must be from the same project (Settings → API).
# Either use VITE_* (preferred) OR plain names below — vite.config maps SUPABASE_* → client (service role is never bundled).
# VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_public_key
# Same values, Lovable-style names (also work):
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_ANON_KEY=your_anon_public_key
# Never put SUPABASE_SERVICE_KEY in the frontend repo or Lovable "public" env — server only. Never commit real keys.
#
# Edge Function `tracerfy-skip-trace` (Skip Trace in Brivano Scout): set BATCHDATA_API_KEY in Supabase
# (Dashboard → Edge Functions → Secrets, or `supabase secrets set BATCHDATA_API_KEY=your_key --project-ref ...`).
# Without it, skip trace returns a clear error instead of BatchData results.
