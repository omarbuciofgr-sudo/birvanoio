# Scraper backend (Trulia/Hotpads, Skip Trace).
# Local:   http://localhost:8080
# Deployed: https://resplendent-empathy-production.up.railway.app
# VITE_SCRAPER_BACKEND_URL=http://localhost:8080
# VITE_SCRAPER_BACKEND_URL=https://resplendent-empathy-production.up.railway.app

# Optional: show Admin section on production (brivano.io) for these emails (comma-separated).
# If unset, any user with @brivano.io email sees Admin on www.brivano.io.
# VITE_ADMIN_EMAILS=info@brivano.io,admin@brivano.io

# Supabase — required (Vite bakes these in at *build* time).
# Dashboard: Project Settings → API → Project URL + anon "public" key
# VITE_SUPABASE_URL=https://xgcvdduwrvgquurhngzq.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
#
# If production shows "supabaseUrl is required", add both in Lovable (Environment variables) or CI, then redeploy.
